    await msg.answer(f"🎵 Твой плейлист:\n{url}" if url else "Плейлист не найден.")


@dp.message_handler(lambda msg: msg.text == MUSIC_BTN)
async def btn_music_during_session(msg: types.Message):
    playlists = load_playlists()
    url = playlists.get(str(msg.from_user.id))
    if url:
        await send_playlist(msg.chat.id, url)
    else:
        await msg.answer("Плейлист не найден.")


@dp.message_handler(lambda msg: msg.text == "❌ Удалить плейлист")
async def btn_remove_playlist(msg: types.Message):
    playlists = load_playlists()
    uid = str(msg.from_user.id)
    if uid in playlists:
        del playlists[uid]
        save_playlists(playlists)
        await msg.answer("🗑 Плейлист удалён.", reply_markup=get_keyboard(msg.from_user.id))
    else:
        await msg.answer("У тебя нет сохранённого плейлиста.")


# ── Bot timer (keyboard-based) ────────────────────────────────────────────────

@dp.message_handler(lambda msg: msg.text in TIMER_LABELS)
async def start_timer(msg: types.Message):
    uid = msg.from_user.id
    if uid in active_sessions:
        await msg.answer("У тебя уже идёт сессия. Останови её перед началом новой.")
        return
    minutes = TIMER_LABELS[msg.text]
    playlists = load_playlists()
    url = playlists.get(str(uid), DEFAULT_MUSIC_URL)
    await msg.answer(f"Фокус на {minutes} минут. Не сливайся.")
    await send_playlist(msg.chat.id, url)
    task = asyncio.create_task(run_timer(uid, msg.chat.id, minutes))
    active_sessions[uid] = task
    await msg.answer("Сессия идёт. Удачи.", reply_markup=get_keyboard(uid))


@dp.message_handler(lambda msg: msg.text == STOP_BTN)
async def stop_timer(msg: types.Message):
    uid = msg.from_user.id
    task = active_sessions.pop(uid, None)
    if task:
        task.cancel()
    waiting_for_thief[uid] = True
    await msg.answer(
        "Сессия остановлена.\n\nКто или что украло твой фокус?",
        reply_markup=ReplyKeyboardRemove(),
    )


# ── Mini app events ───────────────────────────────────────────────────────────

@dp.message_handler(content_types=types.ContentTypes.WEB_APP_DATA)
async def handle_webapp_data(msg: types.Message):
    uid = msg.from_user.id
    try:
        data = json.loads(msg.web_app_data.data)
    except Exception:
        return

    action = data.get("action")
    minutes = data.get("minutes", 0)

    if action == "start":
        playlists = load_playlists()
        url = playlists.get(str(uid), DEFAULT_MUSIC_URL)
        await msg.answer(
            f"🎯 Сессия {minutes} минут начата!\nНе сливайся.",
            reply_markup=get_keyboard(uid),
        )
        await send_playlist(msg.chat.id, url)

    elif action == "complete":
        await msg.answer(
            f"⏰ Сессия {minutes} минут завершена!\n\n"
            "Ты продержался — отличная работа 💪\n"
            "Сделай перерыв, встань, подыши.",
            reply_markup=get_keyboard(uid),
        )

    elif action == "stop":
        elapsed = data.get("elapsed_minutes", 0)
        waiting_for_thief[uid] = True
        await msg.answer(
            f"Сессия остановлена (прошло ~{elapsed} мин).\n\nКто или что украло твой фокус?",
            reply_markup=ReplyKeyboardRemove(),
        )


# ── "Who stole focus" answer ──────────────────────────────────────────────────

@dp.message_handler(lambda msg: msg.from_user.id in waiting_for_thief)
async def handle_thief(msg: types.Message):
    uid = msg.from_user.id
    waiting_for_thief.pop(uid, None)
    await msg.answer(
        f"Запомни: «{msg.text}» — твой враг.\nВ следующий раз держись крепче. 💪",
        reply_markup=get_keyboard(uid),
    )


# ── Dev startup (polling + local music API) ───────────────────────────────────

class _MusicAPIHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path != "/api/music":
            self.send_error(404)
            return
        cache = load_music_cache()
        file_path = cache.get("file_path")
        if not file_path:
            self.send_error(503, "Music not cached yet")
            return
        cdn_url = f"https://api.telegram.org/file/bot{BOT_TOKEN}/{file_path}"
        try:
            with urllib.request.urlopen(cdn_url) as resp:
                content = resp.read()
                ct = resp.headers.get("Content-Type", "audio/ogg")
            self.send_response(200)
            self.send_header("Content-Type", ct)
            self.send_header("Content-Length", str(len(content)))
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Cache-Control", "no-cache")
            self.end_headers()
            self.wfile.write(content)
        except Exception as exc:
            self.send_error(500, str(exc))

    def log_message(self, fmt, *args):
        pass


def _start_music_api_server():
    HTTPServer(("0.0.0.0", MUSIC_API_PORT), _MusicAPIHandler).serve_forever()


async def _on_startup(_dp):
    # Remove any webhook set by the production server so polling works in dev
    try:
        await bot.delete_webhook(drop_pending_updates=True)
    except Exception:
        pass
    await set_menu_button()
    await refresh_music_cache()
    t = threading.Thread(target=_start_music_api_server, daemon=True)
    t.start()


if __name__ == "__main__":
    executor.start_polling(dp, skip_updates=True, on_startup=_on_startup)
