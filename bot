# ── Bot timer (keyboard-based) ────────────────────────────────────────────────

@dp.message_handler(lambda msg: msg.text in TIMER_LABELS)
async def start_timer(msg: types.Message):
    uid = msg.from_user.id
    if uid in active_sessions:
        await msg.answer("У тебя уже идёт сессия. Останови её перед началом новой.")
        return
    
    minutes = TIMER_LABELS[msg.text]
    playlists = load_playlists()
    url = playlists.get(str(uid), DEFAULT_MUSIC_URL)
    
    # Проверяем, есть ли задача без таймера
    todos_data = load_todos(str(uid))
    today_str = date.today().isoformat()
    pending_tasks = [t for t in todos_data["tasks"] if t.get("date") == today_str]
    
    if pending_tasks:
        # Спрашиваем, на какую задачу запустить таймер
        kb = InlineKeyboardMarkup(row_width=1)
        for task in pending_tasks[:5]:  # Ограничиваем 5 задачами
            kb.add(InlineKeyboardButton(task["name"], callback_data=f"task_{task['name']}"))
        kb.add(InlineKeyboardButton("❌ Без задачи", callback_data="task_none"))
        await msg.answer("Выбери задачу для этой сессии:", reply_markup=kb)
        # Сохраняем параметры сессии
        waiting_for_thief[uid] = {"minutes": minutes, "url": url, "chat_id": msg.chat.id}
    else:
        # Запускаем без задачи
        await msg.answer(f"Фокус на {minutes} минут. Не сливайся.")
        await send_playlist(msg.chat.id, url)
        task = asyncio.create_task(run_timer(uid, msg.chat.id, minutes, None))
        active_sessions[uid] = {"task": task, "task_name": None, "minutes": minutes}


@dp.callback_query_handler(lambda c: c.data.startswith("task_"))
async def process_task_selection(callback: types.CallbackQuery):
    uid = callback.from_user.id
    session_data = waiting_for_thief.pop(uid, None)
    
    if not session_data:
        await callback.answer("Сессия не найдена. Попробуй снова.")
        return
    
    task_name = callback.data[5:]  # убираем "task_"
    if task_name == "none":
        task_name = None
    
    minutes = session_data["minutes"]
    url = session_data["url"]
    chat_id = session_data["chat_id"]
    
    await callback.message.delete()
    await callback.message.answer(f"Фокус на {minutes} минут{', задача: ' + task_name if task_name else ''}. Не сливайся.")
    await send_playlist(chat_id, url)
    
    task = asyncio.create_task(run_timer(uid, chat_id, minutes, task_name))
    active_sessions[uid] = {"task": task, "task_name": task_name, "minutes": minutes}
    await callback.answer()


@dp.message_handler(lambda msg: msg.text == STOP_BTN)
async def stop_timer(msg: types.Message):
    uid = msg.from_user.id
    session = active_sessions.pop(uid, None)
    if session and session["task"]:
        session["task"].cancel()
    waiting_for_thief[uid] = True
    await msg.answer(
        "Сессия остановлена.\n\nКто или что украло твой фокус?",
        reply_markup=ReplyKeyboardRemove(),
    )


# ── Mini app events ───────────────────────────────────────────────────────────

@dp.message_handler(content_types=types.ContentTypes.WEB_APP_DATA)
async def handle_webapp_data(msg: types.Message):
    uid = msg.from_user.id
    try:
        data = json.loads(msg.web_app_data.data)
    except Exception:
        return

    action = data.get("action")
    
    if action == "save_tasks":
        # Сохраняем список задач из мини-приложения
        tasks = data.get("tasks", [])
        today_str = date.today().isoformat()
        todos_data = load_todos(str(uid))
        todos_data["tasks"] = [{"name": t, "date": today_str, "created_at": datetime.now().isoformat()} for t in tasks]
        save_todos(str(uid), todos_data)
        await msg.answer(f"✅ Сохранено {len(tasks)} задач на сегодня!", reply_markup=get_keyboard(uid))
    
    elif action == "start_task":
        task_name = data.get("task_name")
        minutes = data.get("minutes", 25)
        
        if uid in active_sessions:
            await msg.answer("У тебя уже идёт сессия. Останови её перед началом новой.")
            return
        
        playlists = load_playlists()
        url = playlists.get(str(uid), DEFAULT_MUSIC_URL)
        
        await msg.answer(
            f"🎯 Сессия {minutes} минут на задачу «{task_name}» начата!\nНе сливайся.",
            reply_markup=get_keyboard(uid),
        )
        await send_playlist(msg.chat.id, url)
        
        task = asyncio.create_task(run_timer(uid, msg.chat.id, minutes, task_name))
        active_sessions[uid] = {"task": task, "task_name": task_name, "minutes": minutes}

    elif action == "complete":
        minutes = data.get("minutes", 0)
        task_name = data.get("task_name")
        
        # Отмечаем задачу как выполненную
        if task_name:
            todos_data = load_todos(str(uid))
            today_str = date.today().isoformat()
            todos_data["tasks"] = [t for t in todos_data["tasks"] if not (t.get("name") == task_name and t.get("date") == today_str)]
            todos_data["history"].append({
                "name": task_name,
                "date": today_str,
                "duration": minutes,
                "completed_at": datetime.now().isoformat()
            })
            save_todos(str(uid), todos_data)
        
        await msg.answer(
            f"⏰ Сессия {minutes} минут завершена!\n\n"
            "Ты продержался — отличная работа 💪\n"
            "Сделай перерыв, встань, подыши.",
            reply_markup=get_keyboard(uid),
        )

    elif action == "stop":
        elapsed = data.get("elapsed_minutes", 0)
        waiting_for_thief[uid] = True
        await msg.answer(
            f"Сессия остановлена (прошло ~{elapsed} мин).\n\nКто или что украло твой фокус?",
            reply_markup=ReplyKeyboardRemove(),
        )


