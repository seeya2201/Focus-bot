@dp.message_handler(commands=["todos"])
async def cmd_show_todos(msg: types.Message):
    todos_data = load_todos(str(msg.from_user.id))
    today_str = date.today().isoformat()
    today_tasks = [t for t in todos_data["tasks"] if t.get("date") == today_str]
    
    if not today_tasks:
        await msg.answer(
            "📋 На сегодня задач нет.\n\n"
            "Добавь задачи через мини-приложение (кнопка 🎯 Задачи) "
            "или командой /addtask <задача>"
        )
        return
    
    task_list = "\n".join([f"• {t['name']}" for t in today_tasks])
    await msg.answer(
        f"📋 Задачи на сегодня ({date.today().strftime('%d.%m.%Y')}):\n\n{task_list}\n\n"
        f"✅ Выполнено сегодня: {len(todos_data['history'])} задач"
    )


@dp.message_handler(commands=["addtask"])
async def cmd_add_task(msg: types.Message):
    task_name = msg.get_args().strip()
    if not task_name:
        await msg.answer("Укажи название задачи.\nПример: /addtask Написать отчет")
        return
    
    todos_data = load_todos(str(msg.from_user.id))
    today_str = date.today().isoformat()
    
    # Проверяем, нет ли уже такой задачи на сегодня
    existing = [t for t in todos_data["tasks"] if t.get("name") == task_name and t.get("date") == today_str]
    if existing:
        await msg.answer("❌ Такая задача уже есть на сегодня!")
        return
    
    todos_data["tasks"].append({
        "name": task_name,
        "date": today_str,
        "created_at": datetime.now().isoformat()
    })
    save_todos(str(msg.from_user.id), todos_data)
    await msg.answer(f"✅ Задача «{task_name}» добавлена на сегодня!", reply_markup=get_keyboard(msg.from_user.id))


@dp.message_handler(commands=["removetask"])
async def cmd_remove_task(msg: types.Message):
    task_name = msg.get_args().strip()
    if not task_name:
        await msg.answer("Укажи название задачи.\nПример: /removetask Написать отчет")
        return
    
    todos_data = load_todos(str(msg.from_user.id))
    today_str = date.today().isoformat()
    
    original_len = len(todos_data["tasks"])
    todos_data["tasks"] = [t for t in todos_data["tasks"] if not (t.get("name") == task_name and t.get("date") == today_str)]
    
    if len(todos_data["tasks"]) < original_len:
        save_todos(str(msg.from_user.id), todos_data)
        await msg.answer(f"✅ Задача «{task_name}» удалена!")
    else:
        await msg.answer("❌ Задача не найдена.")


@dp.message_handler(commands=["stats"])
async def cmd_stats(msg: types.Message):
    todos_data = load_todos(str(msg.from_user.id))
    history = todos_data["history"]
    
    if not history:
        await msg.answer("📊 Статистика пока пуста. Выполни несколько сессий!")
        return
    
    total_sessions = len(history)
    total_minutes = sum(h["duration"] for h in history)
    avg_duration = total_minutes / total_sessions if total_sessions else 0
    
    # Группировка по дням
    days_stats = {}
    for h in history:
        day = h["date"]
        days_stats[day] = days_stats.get(day, 0) + 1
    
    best_day = max(days_stats.items(), key=lambda x: x[1]) if days_stats else (None, 0)
    
    await msg.answer(
        f"📊 Твоя статистика:\n\n"
        f"• Всего сессий: {total_sessions}\n"
        f"• Всего минут: {total_minutes}\n"
        f"• Средняя длительность: {avg_duration:.0f} мин\n"
        f"• Лучший день: {best_day[0]} ({best_day[1]} задач)" if best_day[0] else "• Лучший день: пока нет"
    )


