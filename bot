import asyncio
import json
import os
import re
import threading
import urllib.request
from http.server import BaseHTTPRequestHandler, HTTPServer

from aiogram import Bot, Dispatcher, types
from aiogram.types import (
    ReplyKeyboardMarkup,
    KeyboardButton,
    ReplyKeyboardRemove,
    InlineKeyboardMarkup,
    InlineKeyboardButton,
    WebAppInfo,
)
from aiogram.utils import executor

from storage import (
    load_playlists, save_playlists,
    load_music_cache, save_music_cache,
)

BOT_TOKEN = os.environ["TELEGRAM_BOT_TOKEN"]

_domains = os.environ.get("REPLIT_DOMAINS", "") or os.environ.get("REPLIT_DEV_DOMAIN", "")
WEBAPP_URL = f"https://{_domains.split(',')[0]}" if _domains else ""

DEFAULT_MUSIC_URL = "https://t.me/musicforbot1/2"
MUSIC_API_PORT = 8765

TELEGRAM_POST_RE = re.compile(r"(?:https?://)?t\.me/([^/\s]+)/(\d+)")

bot = Bot(token=BOT_TOKEN)
dp = Dispatcher(bot)

active_sessions: dict = {}
waiting_for_thief: dict = {}

TIMER_LABELS = {
    "▶️ Старт 25 мин": 25,
    "▶️ Старт 40 мин": 40,
    "▶️ Старт 60 мин": 60,
    "▶️ Старт 90 мин": 90,
    "▶️ Старт 120 мин": 120,
}
STOP_BTN = "⏹ Остановить сессию"
MUSIC_BTN = "🎵 Музыка"


# ── Helpers ──────────────────────────────────────────────────────────────────

def parse_telegram_post(url: str):
    m = TELEGRAM_POST_RE.search(url)
    if m:
        return f"@{m.group(1)}", int(m.group(2))
    return None


def get_keyboard(user_id: int) -> ReplyKeyboardMarkup:
    kb = ReplyKeyboardMarkup(resize_keyboard=True)
    playlists = load_playlists()
    has_playlist = str(user_id) in playlists

    if user_id in active_sessions:
        kb.add(KeyboardButton(STOP_BTN))
        if has_playlist:
            kb.add(KeyboardButton(MUSIC_BTN))
        return kb

    kb.add(KeyboardButton("▶️ Старт 25 мин"), KeyboardButton("▶️ Старт 40 мин"))
    kb.add(KeyboardButton("▶️ Старт 60 мин"), KeyboardButton("▶️ Старт 90 мин"))
    kb.add(KeyboardButton("▶️ Старт 120 мин"))
    if has_playlist:
        kb.add(KeyboardButton("🎵 Мой плейлист"), KeyboardButton("❌ Удалить плейлист"))
    else:
        kb.add(KeyboardButton("🎵 Добавить плейлист"))
    return kb


def get_webapp_inline_keyboard() -> InlineKeyboardMarkup | None:
    if not WEBAPP_URL:
        return None
    return InlineKeyboardMarkup(inline_keyboard=[[
        InlineKeyboardButton(text="🎯 Открыть таймер", web_app=WebAppInfo(url=WEBAPP_URL))
    ]])


async def set_menu_button():
    """Set the chat menu button to open the mini app (shows as a button left of the text field)."""
    if not WEBAPP_URL:
        return
    loop = asyncio.get_event_loop()

    def _request():
        import urllib.parse
        url = f"https://api.telegram.org/bot{BOT_TOKEN}/setChatMenuButton"
        data = urllib.parse.urlencode({
            "menu_button": json.dumps({
                "type": "web_app",
                "text": "🎯 Таймер",
                "web_app": {"url": WEBAPP_URL},
            })
        }).encode()
        try:
            urllib.request.urlopen(url, data=data)
        except Exception:
            pass

    await loop.run_in_executor(None, _request)


async def _cache_music_from_msg(msg: types.Message):
    file_id = None
    if msg.audio:
        file_id = msg.audio.file_id
    elif msg.voice:
        file_id = msg.voice.file_id
    elif msg.document:
        file_id = msg.document.file_id
    if not file_id:
        return
    try:
        info = await bot.get_file(file_id)
        save_music_cache({"file_id": file_id, "file_path": info.file_path})
    except Exception:
        pass


async def refresh_music_cache():
    cache = load_music_cache()
    file_id = cache.get("file_id")
    if not file_id:
        return
    try:
        info = await bot.get_file(file_id)
        cache["file_path"] = info.file_path
        save_music_cache(cache)
    except Exception:
        pass


async def send_playlist(chat_id: int, url: str):
    tg_post = parse_telegram_post(url)
    if tg_post:
        channel, message_id = tg_post
        try:
            fwd = await bot.forward_message(
                chat_id=chat_id, from_chat_id=channel, message_id=message_id
            )
            await _cache_music_from_msg(fwd)
            return
        except Exception:
            pass
    await bot.send_message(chat_id=chat_id, text=f"🎵 Включай плейлист:\n{url}")


async def run_timer(user_id: int, chat_id: int, minutes: int):
    try:
        await asyncio.sleep(minutes * 60)
        active_sessions.pop(user_id, None)
        await bot.send_message(
            chat_id=chat_id,
            text=(
                f"⏰ Сессия {minutes} минут завершена!\n\n"
                "Ты продержался — отличная работа.\n"
                "Сделай перерыв, встань, подыши.\n\n"
                "Готов к следующему раунду? Нажми ▶️ или открой таймер 🎯"
            ),
            reply_markup=get_keyboard(user_id),
        )
    except asyncio.CancelledError:
        pass


# ── /start ────────────────────────────────────────────────────────────────────

@dp.message_handler(commands=["start"])
async def cmd_start(msg: types.Message):
    inline_kb = get_webapp_inline_keyboard()
    text = (
        "Готов работать? 💪\n\n"
        "Открой таймер кнопкой ниже — она также закреплена вверху чата.\n"
        "Плейлист: /setplaylist <ссылка>"
    )
    await msg.answer(text, reply_markup=get_keyboard(msg.from_user.id))
    if inline_kb:
        timer_msg = await msg.answer("🎯 Нажми чтобы открыть таймер:", reply_markup=inline_kb)
        try:
            await bot.pin_chat_message(
                chat_id=msg.chat.id,
                message_id=timer_msg.message_id,
                disable_notification=True,
            )
        except Exception:
            pass


# ── Playlist commands ─────────────────────────────────────────────────────────

@dp.message_handler(commands=["setplaylist"])
async def cmd_set_playlist(msg: types.Message):
    args = msg.get_args().strip()
    if not args:
        await msg.answer("Укажи ссылку.\nПример: /setplaylist https://t.me/channelname/2")
        return
    playlists = load_playlists()
    playlists[str(msg.from_user.id)] = args
    save_playlists(playlists)
    tg_post = parse_telegram_post(args)
    text = (
        "✅ Плейлист сохранён! Telegram-пост будет переслан при старте сессии."
        if tg_post else
        "✅ Плейлист сохранён! Ссылка будет отправлена при старте."
    )
    await msg.answer(text, reply_markup=get_keyboard(msg.from_user.id))


@dp.message_handler(commands=["myplaylist"])
async def cmd_my_playlist(msg: types.Message):
    playlists = load_playlists()
    url = playlists.get(str(msg.from_user.id))
    if url:
        await msg.answer(f"🎵 Твой плейлист:\n{url}")
    else:
        await msg.answer("Нет плейлиста. Добавь через /setplaylist <ссылка>")


# ── Keyboard buttons ──────────────────────────────────────────────────────────

@dp.message_handler(lambda msg: msg.text == "🎵 Добавить плейлист")
async def btn_add_playlist(msg: types.Message):
    await msg.answer(
        "Отправь: /setplaylist <ссылка>\n\n"
        "Поддерживаются Telegram-посты, YouTube, Spotify и любые ссылки."
    )


@dp.message_handler(lambda msg: msg.text == "🎵 Мой плейлист")
async def btn_my_playlist(msg: types.Message):
    playlists = load_playlists()
